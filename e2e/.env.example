# Full E2E Environment Variables Configuration
BASE_URL=http://localhost:3000

# Seed Accounts matching database seed (backend/src/seed.py)
# Default password for all seed accounts: 123456

# 1. Learner / Student Role
TEST_LEARNER_EMAIL=learner@coursera.ai
TEST_LEARNER_PASSWORD=123456

# 2. Instructor Role
TEST_INSTRUCTOR_EMAIL=instructor@coursera.ai
TEST_INSTRUCTOR_PASSWORD=123456

# 3. Teaching Assistant (TA) Role
TEST_TA_EMAIL=ta@coursera.ai
TEST_TA_PASSWORD=123456

# 4. Super Admin Role
TEST_ADMIN_EMAIL=admin@coursera.ai
TEST_ADMIN_PASSWORD=123456

# 5. University / Corporate Partner Admin Role
TEST_PARTNER_EMAIL=partner@coursera.ai
TEST_PARTNER_PASSWORD=123456
