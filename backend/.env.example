# ====================================================================
# ENVIRONMENT CONFIGURATION FOR BACKEND & DOCKER INFRASTRUCTURE
# Instruction: Copy this file to .env in backend/ before running
# ====================================================================

# --------------------------------------------------------------------
# 1. DOCKER POSTGRESQL INFRASTRUCTURE (Used by docker-compose)
# --------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=coursera_admin
POSTGRES_PASSWORD=coursera_password123
POSTGRES_DB=coursera_lms

# --------------------------------------------------------------------
# 2. DOCKER MINIO S3 INFRASTRUCTURE (Used by docker-compose)
# --------------------------------------------------------------------
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password123

# --------------------------------------------------------------------
# 3. UNIFIED PYTHON APP CONFIGURATION (Parsed by Pydantic Settings)
# --------------------------------------------------------------------
ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Connection Strings & Credentials for Application Use
DATABASE_URL=postgresql://coursera_admin:coursera_password123@localhost:5432/coursera_lms
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password123
MINIO_BUCKET_NAME=coursera-assets
MINIO_SECURE=false

# --------------------------------------------------------------------
# 4. JWT AUTHENTICATION & TOKEN EXPIRATION
# --------------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_coursera_2026_change_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
