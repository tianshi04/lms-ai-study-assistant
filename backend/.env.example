# ==========================================
# THÔNG TIN CẤU HÌNH MÔI TRƯỜNG DỰ ÁN BACKEND (PYTHON CONNECTRPC)
# Copy file này thành .env ở thư mục backend/ trước khi chạy
# ==========================================

# 1. PostgreSQL PGVector Database (PostgreSQL 17)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=coursera_admin
POSTGRES_PASSWORD=coursera_password123
POSTGRES_DB=coursera_lms
DATABASE_URL=postgresql://coursera_admin:coursera_password123@localhost:5432/coursera_lms

# 2. MinIO / S3 Compatible Object Storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password123
MINIO_BUCKET_NAME=coursera-assets
MINIO_USE_SSL=false

# 3. Backend Server Config
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
JWT_SECRET=your_super_secret_jwt_key_coursera_2026_change_in_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 4. Gemini LLM API (Coursera AI Coach & RAG Embedding)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
